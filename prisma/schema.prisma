////////////////////////////////////////////////////////////
// Generator & Datasource (REQUIRED)                      //
////////////////////////////////////////////////////////////

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

////////////////////////////////////////////////////////////
// Enums                                                  //
////////////////////////////////////////////////////////////

enum UserRole {
  ADMIN
  TAILOR
  CUSTOMER
}

enum EcommerceOrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum StitchingOrderStatus {
  PENDING
  ASSIGNED
  STITCHING
  QC
  COMPLETED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum TailorPayoutStatus {
  PENDING
  APPROVED
  PAID
}

enum ClothType {
  COTTON
  SILK
  WOOL
  LINEN
  POLYESTER
  BLEND
  CUSTOM
}

enum ClothSource {
  OWN
  FROM_US
}

enum ProductMasterType {
  CATEGORY
  SUBCATEGORY
  CLOTH_TYPE
  MATERIAL
  SIZE
  COLOR
}

enum ChatMessageType {
  TEXT
  COMPLAINT
  SYSTEM
}

enum ComplaintStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  REJECTED
}

////////////////////////////////////////////////////////////
// Models                                                 //
////////////////////////////////////////////////////////////

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  password     String
  role         UserRole @default(CUSTOMER)
  profileImage String?
  phone        String?
  dateOfBirth  DateTime?
  notifyEmail  Boolean  @default(true)
  notifyPush   Boolean  @default(false)
  notifyOrders Boolean  @default(true)
  notifyOffers Boolean  @default(false)
  cart         Json?
  wishlist     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tailorProfile     TailorProfile?
  customerAddresses Address[]
  measurements      Measurement[]

  orders          Order[]          @relation("CustomerOrders")
  stitchingOrders StitchingOrder[] @relation("CustomerStitchingOrders")
  assignments     Assignment[]     @relation("TailorAssignments")

  customerReviews Review[] @relation("CustomerReviews")
  tailorReviews   Review[] @relation("TailorReviews")
  productReviews  ProductReview[] @relation("CustomerProductReviews")

  payments Payment[]
  notifications Notification[]
  pushSubscriptions PushSubscription[]
  sentChatMessages OrderMessage[] @relation("OrderMessageSender")
  orderConversationsAsCustomer OrderConversation[] @relation("OrderConversationCustomer")
  orderConversationsAsTailor OrderConversation[] @relation("OrderConversationTailor")
  handledComplaints ReturnComplaint[] @relation("ComplaintHandledBy")
  complaintsRaised ReturnComplaint[] @relation("ComplaintRaisedBy")

  @@index([email])
  @@index([role])
}

model TailorProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  bio             String?
  specializations String?
  yearsExperience Int      @default(0)
  averageRating   Float    @default(0)
  totalOrders     Int      @default(0)
  totalEarnings   Float    @default(0)
  monthlyEarnings Float    @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews     Review[]
  assignments Assignment[]

  @@index([userId])
  @@index([isActive])
}

model StitchingService {
  id            String   @id @default(cuid())
  key           String   @unique
  category      String
  name          String
  measurementType String? @default("GENERIC")
  measurementFields Json?
  measurementGuideImage String?
  customerPrice Float
  tailorRate    Float
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category])
  @@index([isActive])
}

model Address {
  id         String   @id @default(cuid())
  userId     String
  street     String
  city       String
  state      String
  postalCode String
  country    String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
}

model Measurement {
  id            String   @id @default(cuid())
  userId        String
  name          String
  isVerified    Boolean  @default(false)
  source        String?  @default("CUSTOMER")
  verifiedByAdminId String?
  verifiedAt    DateTime?
  measurementType String?
  measurementData Json?
  chest         Float?
  waist         Float?
  hip           Float?
  shoulder      Float?
  sleeveLength  Float?
  garmentLength Float?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  stitchingOrders StitchingOrder[]

  @@index([userId])
}

model Product {
  id             String   @id @default(cuid())
  name           String
  slug           String?  @unique
  description    String?
  price          Float
  image          String?
  images         Json?
  videos         Json?
  category       String
  subcategory    String?
  clothType      String?
  size           String?
  color          String?
  colors         Json?
  material       String?
  tags           Json?
  highlights     Json?
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  canonicalUrl   String?
  categoryId     String?
  subcategoryId  String?
  clothTypeId    String?
  materialId     String?
  stock          Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orderItems OrderItem[]
  faqs      ProductFaq[]
  reviews   ProductReview[]
  categoryMaster ProductMaster? @relation("ProductCategoryMaster", fields: [categoryId], references: [id])
  subcategoryMaster ProductMaster? @relation("ProductSubcategoryMaster", fields: [subcategoryId], references: [id])
  clothTypeMaster ProductMaster? @relation("ProductClothTypeMaster", fields: [clothTypeId], references: [id])
  materialMaster ProductMaster? @relation("ProductMaterialMaster", fields: [materialId], references: [id])
  masterSelections ProductMasterSelection[]

  @@index([category])
  @@index([isActive])
  @@index([clothType])
  @@index([slug])
  @@index([categoryId])
  @@index([subcategoryId])
  @@index([clothTypeId])
  @@index([materialId])
}

model ProductMaster {
  id        String            @id @default(cuid())
  name      String
  slug      String
  type      ProductMasterType
  isActive  Boolean           @default(true)
  parentId  String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  parent   ProductMaster?  @relation("ProductMasterHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children ProductMaster[] @relation("ProductMasterHierarchy")

  categoryProducts    Product[]               @relation("ProductCategoryMaster")
  subcategoryProducts Product[]               @relation("ProductSubcategoryMaster")
  clothTypeProducts   Product[]               @relation("ProductClothTypeMaster")
  materialProducts    Product[]               @relation("ProductMaterialMaster")
  selections          ProductMasterSelection[]

  @@unique([type, slug])
  @@index([type, isActive])
  @@index([parentId])
}

model ProductMasterSelection {
  id        String   @id @default(cuid())
  productId String
  masterId  String
  createdAt DateTime @default(now())

  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  master  ProductMaster @relation(fields: [masterId], references: [id], onDelete: Cascade)

  @@unique([productId, masterId])
  @@index([masterId])
  @@index([productId])
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products ProductFaq[]

  @@index([isActive])
  @@index([category])
}

model ProductFaq {
  id        String   @id @default(cuid())
  productId String
  faqId     String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  faq     Faq     @relation(fields: [faqId], references: [id], onDelete: Cascade)

  @@unique([productId, faqId])
  @@index([productId, order])
  @@index([faqId])
}

model BlogPost {
  id                    String   @id @default(cuid())
  title                 String
  slug                  String   @unique
  excerpt               String
  contentHtml           String
  category              String
  coverImage            String?
  coverImageBlurDataUrl String?
  seoTitle              String?
  seoDescription        String?
  seoKeywords           String?
  ogTitle               String?
  ogDescription         String?
  ogImage               String?
  ogImageBlurDataUrl    String?
  canonicalUrl          String?
  isPublished           Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([category])
  @@index([isPublished])
  @@index([createdAt])
}

model Order {
  id            String        @id @default(cuid())
  customerId    String
  addressId     String
  orderNumber   String        @unique
  status        EcommerceOrderStatus @default(PENDING)
  totalAmount   Float
  paymentStatus PaymentStatus @default(PENDING)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deliveredAt   DateTime?

  customer User        @relation("CustomerOrders", fields: [customerId], references: [id], onDelete: Cascade)
  address  Address     @relation(fields: [addressId], references: [id])
  items    OrderItem[]
  productReviews ProductReview[]
  payments Payment[]

  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  createdAt DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model StitchingOrder {
  id               String      @id @default(cuid())
  customerId       String
  measurementId    String
  clothType        ClothType
  clothSource      ClothSource @default(OWN)
  clothName        String?
  clothPrice       Float       @default(0)
  stitchingPrice   Float       @default(0)
  fabricImage      String?
  completedImage   String?
  serviceKey       String?
  stitchingService String
  price            Float
  status           StitchingOrderStatus @default(PENDING)
  contactName      String?
  contactPhone     String?
  addressLine1     String?
  addressCity      String?
  addressState     String?
  addressPostalCode String?
  addressCountry   String?
  notes            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  deliveredAt      DateTime?

  customer    User        @relation("CustomerStitchingOrders", fields: [customerId], references: [id], onDelete: Cascade)
  measurement Measurement @relation(fields: [measurementId], references: [id])
  assignment  Assignment?
  payment     Payment?
  conversation OrderConversation?
  complaints  ReturnComplaint[]
  messages    OrderMessage[]

  @@index([customerId])
  @@index([status])
}

model Assignment {
  id               String    @id @default(cuid())
  stitchingOrderId String    @unique
  tailorId         String
  payoutRate       Float     @default(0)
  payoutAmount     Float     @default(0)
  payoutStatus     TailorPayoutStatus @default(PENDING)
  paidAt           DateTime?
  assignedAt       DateTime  @default(now())
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  stitchingOrder  StitchingOrder @relation(fields: [stitchingOrderId], references: [id], onDelete: Cascade)
  tailor          User           @relation("TailorAssignments", fields: [tailorId], references: [id])
  tailorProfile   TailorProfile? @relation(fields: [tailorProfileId], references: [id])
  tailorProfileId String?

  @@index([tailorId])
  @@index([payoutStatus])
}

model Review {
  id               String   @id @default(cuid())
  customerId       String
  tailorId         String
  tailorProfileId  String
  stitchingOrderId String
  rating           Int
  comment          String?
  isApproved       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  customer      User          @relation("CustomerReviews", fields: [customerId], references: [id], onDelete: Cascade)
  tailor        User          @relation("TailorReviews", fields: [tailorId], references: [id], onDelete: Cascade)
  tailorProfile TailorProfile @relation(fields: [tailorProfileId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([tailorId])
  @@index([isApproved])
}

model ProductReview {
  id         String   @id @default(cuid())
  productId  String
  customerId String
  orderId    String
  rating     Int
  title      String?
  comment    String?
  photos     Json?
  isApproved Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product  Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer User    @relation("CustomerProductReviews", fields: [customerId], references: [id], onDelete: Cascade)
  order    Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([productId, customerId])
  @@index([productId, isApproved, createdAt])
  @@index([customerId])
  @@index([orderId])
}

model Payment {
  id               String        @id @default(cuid())
  orderId          String?
  stitchingOrderId String?       @unique
  customerId       String
  amount           Float
  status           PaymentStatus @default(PENDING)
  stripePaymentId  String?
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  order          Order?          @relation(fields: [orderId], references: [id])
  stitchingOrder StitchingOrder? @relation(fields: [stitchingOrderId], references: [id])
  customer       User            @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([status])
  @@index([stripePaymentId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  readAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OrderConversation {
  id              String   @id @default(cuid())
  stitchingOrderId String  @unique
  customerId      String
  tailorId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  stitchingOrder StitchingOrder @relation(fields: [stitchingOrderId], references: [id], onDelete: Cascade)
  customer       User           @relation("OrderConversationCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  tailor         User?          @relation("OrderConversationTailor", fields: [tailorId], references: [id], onDelete: SetNull)
  messages       OrderMessage[]

  @@index([customerId])
  @@index([tailorId])
}

model OrderMessage {
  id             String         @id @default(cuid())
  conversationId String
  stitchingOrderId String
  senderId       String
  type           ChatMessageType @default(TEXT)
  message        String
  isRead         Boolean        @default(false)
  createdAt      DateTime       @default(now())

  conversation   OrderConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  stitchingOrder StitchingOrder    @relation(fields: [stitchingOrderId], references: [id], onDelete: Cascade)
  sender         User              @relation("OrderMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  complaint      ReturnComplaint?

  @@index([conversationId, createdAt])
  @@index([stitchingOrderId, createdAt])
  @@index([senderId, createdAt])
}

model ReturnComplaint {
  id               String          @id @default(cuid())
  stitchingOrderId String
  raisedById       String
  messageId        String?         @unique
  title            String
  details          String
  status           ComplaintStatus @default(OPEN)
  adminNote        String?
  handledById      String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  stitchingOrder StitchingOrder @relation(fields: [stitchingOrderId], references: [id], onDelete: Cascade)
  raisedBy       User          @relation("ComplaintRaisedBy", fields: [raisedById], references: [id], onDelete: Cascade)
  handledBy      User?         @relation("ComplaintHandledBy", fields: [handledById], references: [id], onDelete: SetNull)
  message        OrderMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([stitchingOrderId, createdAt])
  @@index([status, createdAt])
  @@index([raisedById, createdAt])
}
